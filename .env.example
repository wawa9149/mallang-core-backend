# 백엔드 실행에 필요한 환경 변수. 이 파일을 .env로 복사한 뒤 값을 채워라.
# docker-compose.yml의 기본값과 맞춰 둔 상태다.

# 사내 포트 규칙에 따라 백엔드는 8101, Postgres는 호스트 바인딩만 9001을 사용한다.
PORT=8101

# Postgres (docker-compose의 기본 사용자/비밀번호와 일치)
# - 로컬 개발(호스트에서 nest start:dev): host=localhost, port=9001 (compose가 호스트로 노출한 포트)
# - docker compose로 백엔드 컨테이너 함께 띄울 때는 host=postgres, port=5432가 되어야 하는데,
#   docker-compose.yml이 environment.DATABASE_URL로 override하므로 여기에는 로컬 값만 둬도 된다.
DATABASE_URL="postgresql://mallang:mallang@localhost:9001/mallang?schema=public"

# JWT - 운영 환경에서는 반드시 무작위 64자 이상으로 교체
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"

# 사용자별 OpenAI API 키를 AES-256-GCM으로 암호화할 때 사용하는 마스터 키.
# 반드시 64자 hex (= 32 bytes)로, `openssl rand -hex 32`로 생성해라.
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# 사용자가 별도로 키를 등록하지 않은 경우 사용하지 않는다.
# 모델은 사용자별/시스템 공통으로 환경변수에서 override 가능.
OPENAI_MODEL="gpt-4o-mini"

# 카카오 디벨로퍼스의 REST API 키. 점심 추천에서 팀 주소 → 좌표 변환과
# 좌표 기반 주변 음식점(FD6) 동기화에 사용한다.
# https://dapi.kakao.com 의 Authorization 헤더(`KakaoAK ${KAKAO_REST_API_KEY}`)에 사용된다.
# 비어 있으면 카카오 연동 기능은 자동으로 비활성화되고, 시드 식당만으로 추천이 동작한다.
KAKAO_REST_API_KEY=""

# Naver Clova Voice (Naver Cloud Platform → AI·Application Service → CLOVA Voice).
# 둘 다 채우면 /api/tts/speak 엔드포인트가 활성화된다. 어느 한쪽이라도 비어 있으면 503 으로 응답한다.
# 사용자는 마이페이지의 토글로 발화 음성을 켜고 끌 수 있다(User.ttsEnabled).
CLOVA_VOICE_API_KEY_ID=""
CLOVA_VOICE_API_KEY=""
# 기본 화자. 미지정 시 'nara'. 후보 예시: nara, mijin, dara_ang, vyuna, vmikyung, ndaeseong …
CLOVA_VOICE_SPEAKER="nara"
# -5 ~ 5 범위. 부호 규칙은 Naver 문서 그대로(SPEED 양수=느림, PITCH 양수=낮음).
CLOVA_VOICE_SPEED="0"
CLOVA_VOICE_PITCH="0"
CLOVA_VOICE_VOLUME="0"
# 음색/포만트 (-5~5, 기본 0). 양수면 굵직·낮게, 음수면 얇게·높게 들린다.
CLOVA_VOICE_ALPHA="0"

# Magovoice Speech-to-Text. 마이크 버튼으로 녹음한 음성을 텍스트로 받는다.
# - 기본 엔드포인트는 https://op1-api.magovoice.com/speech_to_text/v1/run.
# - Swagger 문서는 https://op1-api.magovoice.com/speech_to_text/docs 에서 확인.
# - API 키가 비어 있어도 (현재 공개 데모) 동작은 한다. 운영 환경에서 키가 필요해지면
#   `Authorization: Bearer <key>` 헤더로 전달되도록 MAGOVOICE_API_KEY 를 채워 두면 된다.
MAGOVOICE_API_URL="https://op1-api.magovoice.com/speech_to_text/v1/run"
MAGOVOICE_API_KEY=""
