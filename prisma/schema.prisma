// Mallang Core Prisma schema
// 마이그레이션: pnpm prisma:migrate
// 스튜디오:    pnpm prisma:studio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Hobby {
  rest
  workout
  self_development
}

enum VoteStatus {
  open
  closed
}

// 말랑이 상태/감정 라벨. 프론트의 MallangState와 1:1 매핑된다.
// '기쁨'=happy / '보통'=neutral / '지침'=tired / '슬픔'=sad / '화남'=angry
enum Emotion {
  happy
  neutral
  tired
  sad
  angry
}

enum ChatRole {
  user
  assistant
}

// 채팅 인텐트.
// free          : 사용자가 직접 말 건 일반 채팅
// morning_check : 출근 시간대 자동 메시지
// lunch_alert   : 점심 시간대 알림(투표)
// lunch_review  : 점심 후 후기 알림
// evening_check : 퇴근 시간대 자동 메시지 (야근 여부 판단 대상)
enum ChatIntent {
  free
  morning_check
  lunch_alert
  lunch_review
  evening_check
}

// 점심 추천에서 다루는 식당 카테고리. 시드 단계에서 충분하도록 큰 묶음 위주로 정의한다.
enum RestaurantCategory {
  korean
  japanese
  chinese
  western
  asian
  snack
  cafe
  // 떡·한과, 베이커리, 디저트 전문점 등 "식사로 적합하지 않은" 메뉴 위주 식당.
  // 점심 추천 hard filter 에서 일괄 제외된다.
  dessert
  etc
}

// 1인 기준 가격대. 사용자 선호의 budgetMax와 매칭에 쓰인다.
enum PriceTier {
  low
  mid
  high
}

// 식이/종교 제한. 식당이 지원하는 값과 사용자 선호가 매칭돼야 후보에 든다.
enum Dietary {
  none
  vegetarian
  vegan
  halal
  kosher
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]
  users User[]

  @@map("companies")
}

model Team {
  id                 String   @id @default(cuid())
  name               String
  companyId          String?
  // 점심 추천 시 반경 계산 기준이 되는 회사/사무실 위치. 도로명 주소만 받고
  // 좌표는 외부 geocoding 연동(Phase 2) 후 채워지므로 모두 nullable이다.
  address            String?
  lat                Float?
  lng                Float?
  // 도보 반경(미터). 좌표가 채워진 뒤부터 hard-filter에 사용한다.
  // 500m는 도보 5~7분 거리(점심 한 끼 다녀오기 적당한 반경)로 기본값을 잡았다.
  searchRadiusMeters Int      @default(500)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company    Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  members    User[]
  lunchVotes LunchVote[]

  // 같은 회사 안에서는 팀명이 유일하다. companyId가 null이면 글로벌 팀명으로 취급.
  @@unique([companyId, name])
  @@map("teams")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  hobby           Hobby    @default(rest)
  workStartTime   String   @default("09:00")
  lunchTime       String   @default("12:30")
  workEndTime     String   @default("18:00")
  allergies       String?
  companyId       String?
  teamId          String?
  // 사용자별 OpenAI API key. AES-256-GCM(`iv:tag:ciphertext` base64)로 저장한다.
  // 평문은 절대 응답에 노출하지 않고, 마스킹된 hint(앞 5자 + ...)만 메타로 제공한다.
  openaiKeyEnc    String?
  openaiKeyUpdatedAt DateTime?
  // 온보딩(필수 정보 입력) 완료 시점. 한 번 채워지면 다시 null 로 돌리지 않는다.
  // 프론트는 이 값의 존재 여부만 보고 OnboardingFlow 노출 여부를 결정한다.
  onboardedAt     DateTime?
  // 말랑이 발화를 Clova Voice TTS 로 들을지 여부. 기본은 끔.
  ttsEnabled      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  votes         LunchVoteOptionVote[]
  emotionLogs   EmotionLog[]
  chatMessages  ChatMessage[]
  preference    UserPreference?
  visits        VisitRecord[]

  @@index([teamId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model LunchVote {
  id             String     @id @default(cuid())
  teamId         String
  title          String     @default("오늘 점심 뭐 먹지?")
  status         VoteStatus @default(open)
  date           DateTime   @default(now())
  closesAt       DateTime?
  // 투표 마감 시점에 결정된 우승 옵션. 동점이면 후보 중 무작위로 1개가 선택된다.
  // 한 번 결정되면 다시 바뀌지 않도록 close 트랜잭션 안에서만 기록한다.
  winnerOptionId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  options LunchVoteOption[]
  // 이 투표 결과로 식당에 다녀온 사용자들의 기록. 점심 후 피드백 단계에서 적재된다.
  visits  VisitRecord[]     @relation("VisitFromVote")

  @@index([teamId, status])
  @@index([status, closesAt])
  @@map("lunch_votes")
}

model LunchVoteOption {
  id           String   @id @default(cuid())
  lunchVoteId  String
  label        String
  // 추천 시스템이 만든 옵션은 식당 row와 연결된다. 자유 입력 옵션은 null.
  restaurantId String?
  // 옵션 생성 시점에 결정론 추천이 만든 한 줄 사유(예: "한식 선호 매칭 · 14일 만에 한 번 더 · 평점 4.4").
  // 추천이 다시 돌아도 그 투표 옵션에 박힌 이유는 변하지 않도록 박제한다. 자유 입력 옵션은 null.
  reason       String?
  createdAt    DateTime @default(now())

  vote       LunchVote             @relation(fields: [lunchVoteId], references: [id], onDelete: Cascade)
  votes      LunchVoteOptionVote[]
  restaurant Restaurant?           @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([lunchVoteId])
  @@index([restaurantId])
  @@map("lunch_vote_options")
}

model LunchVoteOptionVote {
  id        String   @id @default(cuid())
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  option LunchVoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 한 옵션당 한 유저는 1표.
  @@unique([optionId, userId])
  @@map("lunch_vote_option_votes")
}

// 사용자와 말랑이의 대화 한 턴을 표현.
// - role=user 메시지에는 LLM이 분석한 EmotionLog가 1개 연결될 수 있다.
// - role=assistant 메시지에는 분석이 붙지 않는다.
model ChatMessage {
  id        String      @id @default(cuid())
  userId    String
  role      ChatRole
  intent    ChatIntent  @default(free)
  content   String
  // 인텐트별 부가 정보(예: evening_check의 isLeftOffice 결과)는 metadata에 자유 JSON으로 보관.
  metadata  Json?
  createdAt DateTime    @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emotionLogs EmotionLog[]

  @@index([userId, createdAt])
  @@map("chat_messages")
}

model EmotionLog {
  id            String    @id @default(cuid())
  userId        String
  emotion       Emotion   @default(neutral)
  // 감정의 강도 (0~100). 후속 단계에서 말랑이 상태/주간 리포트 점수로 환산된다.
  score         Int       @default(50)
  // LLM이 뽑아낸 키워드(최대 5개).
  keywords      String[]  @default([])
  // 어떤 채팅 메시지(=role:user)에서 추출됐는지. 시간대 자동 메시지/일반 채팅 모두 동일하게 연결.
  chatMessageId String?
  note          String?
  loggedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessage ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: SetNull)

  @@index([userId, loggedAt])
  @@map("emotion_logs")
}

// 점심 추천 후보가 될 식당. 시드 단계에서는 직접 채워 넣고, 카카오 Local API 어댑터로 주기 동기화된다.
// 좌표/영업시간은 외부 API 연동 전엔 nullable이며, 거리 hard-filter는 좌표가 있을 때에만 적용된다.
model Restaurant {
  id                String             @id @default(cuid())
  name              String
  category          RestaurantCategory
  priceTier         PriceTier          @default(mid)
  rating            Float?
  lat               Float?
  lng               Float?
  // 도로명/지번 주소. UI 노출 + 사람이 식별하기 위한 보조 정보.
  address           String?
  // 카카오/구글 등 외부 데이터의 원본 ID. upsert 키로 쓰이며,
  // 시드 데이터처럼 외부 ID가 없는 row는 null로 둔다.
  externalId        String?
  // { "mon": ["11:00","21:00"], "sat": ["closed"], ... } 자유 JSON.
  openHours         Json?
  hasRoom           Boolean            @default(false)
  capacity          Int?
  // 매운맛/국물/단체석 같은 자유 태그. 카테고리 외 미세 매칭에 사용한다.
  tags              String[]           @default([])
  // 이 식당이 사실상 항상 포함하는 알러지원/식이 제한.
  // 팀원의 user.allergies 텍스트에 부분일치하는 토큰이 있으면 후보에서 제외한다.
  excludedAllergens String[]           @default([])
  // 채식/비건/할랄 같은 옵션을 지원하는지. 팀원 선호의 dietary와 매칭한다.
  dietarySupported  Dietary[]          @default([])
  // 데이터 출처/검증.
  source            String             @default("seed")
  lastVerifiedAt    DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  visits            VisitRecord[]
  lunchVoteOptions  LunchVoteOption[]

  @@unique([source, externalId])
  @@index([category])
  @@map("restaurants")
}

// 누가 언제 어떤 식당에 다녀왔는지. 추천에서는 "최근 N일 방문 회피"와 "탐험 슬롯" 판단에 쓰인다.
// rating/note는 Phase 4 피드백 단계에서 채워지며, 그 전까지는 자동 적재된 행만 존재할 수 있다.
model VisitRecord {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  // 어떤 점심 투표 결과로 갔는지(자동 적재용). 수동 기록은 null.
  lunchVoteId  String?
  visitedAt    DateTime   @default(now())
  rating       Int?
  note         String?
  // "이 식당 또 가고 싶어?" 사용자 피드백.
  wantsAgain   Boolean?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lunchVote  LunchVote? @relation("VisitFromVote", fields: [lunchVoteId], references: [id], onDelete: SetNull)

  // 한 사용자가 같은 투표에 대해 중복 리뷰 방지.
  @@unique([userId, lunchVoteId])
  @@index([userId, visitedAt])
  @@index([restaurantId, visitedAt])
  @@map("visit_records")
}

// 사용자의 점심 추천 선호도. 마이페이지에서 입력하지 않아도 추천이 동작하도록 모든 필드가 합리적 디폴트를 갖는다.
// fairnessScore는 "최근에 자기 취향이 덜 반영된 사람일수록 다음 추천에서 더 가중"하기 위한 누적값이다.
model UserPreference {
  id                  String               @id @default(cuid())
  userId              String               @unique
  preferredCategories RestaurantCategory[] @default([])
  dislikedCategories  RestaurantCategory[] @default([])
  budgetMax           Int?
  // 0(매운맛 못 먹음) ~ 3(아주 잘 먹음).
  spicyTolerance      Int                  @default(2)
  dietary             Dietary              @default(none)
  fairnessScore       Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
