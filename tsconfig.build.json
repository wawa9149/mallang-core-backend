{
  "extends": "./tsconfig.json",
  // Nest 빌드는 항상 src/ 만 컴파일한다.
  // include를 명시하지 않으면 baseUrl 아래의 모든 .ts (prisma/seed.ts, scripts/*.ts 등)가 포함되어
  // dist 구조가 dist/{src,prisma,scripts}/... 로 분기되고 dist/main.js 가 사라지는 함정이 있다.
  // 추후 새로운 .ts 도구가 root에 추가돼도 빌드에 끼어들지 않게 include로 못 박는다.
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
